{
	"name": "velix",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently -k -n convex,vite \"npx convex dev\" \"vite dev\"",
		"build": "vite build && npm run budget:bundles",
		"budget:bundles": "node scripts/check-bundle-budgets.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format .",
		"format:write": "biome format --write .",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"effect:diagnostics": "effect-language-service diagnostics --project ./tsconfig.effect.json",
		"effect:diagnostics:convex": "effect-language-service diagnostics --project ./src/convex/tsconfig.json",
		"effect:quickfixes": "effect-language-service quickfixes --project ./tsconfig.effect.json",
		"effect:overview": "effect-language-service overview --project ./tsconfig.effect.json",
		"effect:patch": "effect-language-service patch",
		"test:unit": "vitest",
		"test": "node scripts/run-vitest.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@effect/language-service": "^0.86.2",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/space-grotesk": "^5.2.10",
		"@internationalized/date": "^3.12.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.3",
		"@vitest/browser-playwright": "^4.1.8",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"concurrently": "^10.0.3",
		"playwright": "^1.60.0",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@garmin/fitsdk": "^21.205.0",
		"@lucide/svelte": "^1.17.0",
		"convex": "^1.41.0",
		"convex-svelte": "0.13.0",
		"effect": "^4.0.0-beta.79",
		"maplibre-gl": "^5.24.0",
		"mode-watcher": "^1.1.0",
		"svelte-clerk": "^1.1.9"
	},
	"overrides": {
		"cookie": "^1.1.1",
		"js-cookie": "3.0.8"
	}
}
